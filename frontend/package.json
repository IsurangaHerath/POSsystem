{
    "name": "pos-system",
    "version": "1.0.0",
    "description": "Point of Sale System - Desktop Application",
    "main": "src/main/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "vite build && electron-builder",
        "electron:preview": "vite build && electron ."
    },
    "keywords": [
        "pos",
        "point-of-sale",
        "electron",
        "react"
    ],
    "author": "Your Name",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.6.2",
        "electron-store": "^8.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.20.1"
    },
    "devDependencies": {
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.2",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "postcss": "^8.4.32",
        "tailwindcss": "^3.3.6",
        "vite": "^5.0.8",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.yourcompany.pos",
        "productName": "POS System",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "dist/**/*",
            "src/main/**/*",
            "public/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "public/icons/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "public/icons/icon.icns"
        },
        "linux": {
            "target": "AppImage",
            "icon": "public/icons/icon.png"
        }
    }
}